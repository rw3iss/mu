{
  "name": "mu",
  "private": true,
  "version": "0.1.0",
  "description": "Self-hosted movie streaming and management platform",
  "scripts": {
    "dev": "turbo run dev",
    "dev:server": "turbo run dev --filter=@mu/server",
    "dev:client": "turbo run dev --filter=@mu/client",
    "build": "turbo run build",
    "build:standalone": "cd packages/client && pnpm build:standalone",
    "start": "node packages/server/dist/main.js",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check --write .",
    "test": "turbo run test",
    "db:generate": "cd packages/server && npx drizzle-kit generate",
    "db:migrate": "cd packages/server && npx drizzle-kit push --force",
    "db:push": "cd packages/server && npx drizzle-kit push",
    "db:seed": "cd packages/server && npx tsx src/database/seed.ts",
    "db:studio": "cd packages/server && npx drizzle-kit studio",
    "db:reset": "cd packages/server && node -e \"const fs=require('fs');['data/db/mu.db','data/db/mu.db-shm','data/db/mu.db-wal'].forEach(p=>{try{fs.unlinkSync(p)}catch{}});console.log('Database cleared. Run pnpm db:migrate && pnpm db:seed to reinitialize.')\"",
    "cache:clean": "node scripts/cache-clean.js",
    "clean": "turbo run clean && node -e \"const fs=require('fs');try{fs.rmSync('node_modules',{recursive:true,force:true})}catch{}\"",
    "plugin:generate": "npx tsx scripts/plugin-generate.ts",
    "plugin:generate-client-api": "npx tsx scripts/plugin-generate-client-api.ts",
    "logs": "bash scripts/logs.sh",
    "logs:prod": "bash scripts/logs-prod.sh"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "tsx": "^4.21.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "patchedDependencies": {
      "fluent-ffmpeg": "patches/fluent-ffmpeg.patch"
    }
  }
}
