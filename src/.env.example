# Mu Environment Variables
# Copy to .env and modify as needed

# Server
MU_SERVER_HOST=0.0.0.0
MU_SERVER_PORT=8080
MU_SERVER_LOG_LEVEL=info

# Database
MU_DATABASE_TYPE=sqlite
MU_DATABASE_SQLITE_PATH=./data/db/mu.db
# MU_DATABASE_POSTGRES_URL=postgresql://user:pass@localhost:5432/mu

# Cache
MU_CACHE_TYPE=memory
# MU_CACHE_REDIS_URL=redis://localhost:6379
MU_CACHE_MAX_ENTRIES=10000

# Auth (auto-generated on first run if not set)
# MU_AUTH_JWT_SECRET=
# MU_AUTH_COOKIE_SECRET=
MU_AUTH_LOCAL_BYPASS=true

# Transcoding
MU_TRANSCODING_HW_ACCEL=none
MU_TRANSCODING_MAX_CONCURRENT=2
MU_TRANSCODING_DEFAULT_QUALITY=1080p

# Third-party API Keys
# MU_THIRD_PARTY_TMDB_API_KEY=
# MU_THIRD_PARTY_OMDB_API_KEY=
# MU_THIRD__PARTY__OPENSUBTITLES__API_KEY=

# Data directory
MU_DATA_DIR=./data
